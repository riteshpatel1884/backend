<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit <%=filename%></title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">

    <style>
        body{
            font-family:'IBM Plex Mono', monospace;
            background:#f8fafc;
        }

        .display{
            font-family:'Space Grotesk',sans-serif;
        }

        .card{
            background:#fff;
            border:1px solid #e5e7eb;
            border-radius:20px;
            box-shadow:0 20px 45px rgba(0,0,0,.08);
        }

        .field{
            width:100%;
            border:1px solid #d1d5db;
            border-radius:12px;
            padding:14px 18px;
            transition:.2s;
            background:white;
        }

        .field:focus{
            outline:none;
            border-color:#2563eb;
            box-shadow:0 0 0 4px rgba(37,99,235,.12);
        }

        .btn{
            background:#111827;
            color:white;
            transition:.25s;
        }

        .btn:hover{
            background:#000;
            transform:translateY(-2px);
        }

        .cancel{
            border:1px solid #d1d5db;
            color:#374151;
            transition:.2s;
        }

        .cancel:hover{
            background:#f3f4f6;
        }
    </style>

</head>
<body>

<div class="min-h-screen flex items-center justify-center px-6">

    <div class="w-full max-w-2xl p-10">

        <p class="text-gray-500 mt-2">
            Edit your existing task file.
        </p>

        <form action="/edit" method="POST" class="mt-10 space-y-6">

            <div>
                <label class="block mb-2 text-sm font-semibold text-gray-700">
                    Current Filename
                </label>

                <input
                    type="text"
                    name="previous"
                    readonly
                    value="<%= filename %>"
                    class="field bg-gray-100 cursor-not-allowed">
            </div>

            <div>
                <label class="block mb-2 text-sm font-semibold  text-gray-700">
                    New Filename
                </label>

                <input
                    type="text"
                    name="new_filename"
                    placeholder="Enter new filename"
                    class="field"
                    >
            </div>

             <label class="block mb-2 font-semibold">
               Task Details
             </label>

            <textarea
               name="new_details"
               rows="8"
               class="field resize-none"
               required><%= filedata %>
            </textarea>

        
            <div class="flex gap-4 pt-4">

                <button
                    type="submit"
                    class="btn px-8 py-3 rounded-xl font-semibold">
                    Save Changes
                </button>

                <a
                    href="/"
                    class="cancel px-8 py-3 rounded-xl font-semibold">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>

</body>
</html>
```
