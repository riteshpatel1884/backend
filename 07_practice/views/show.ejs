<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= filename %></title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">

    <style>
        body{
            font-family: 'IBM Plex Mono', monospace;
            background: #ffffff;
        }

        .display{
            font-family: 'Space Grotesk', sans-serif;
        }

        .card{
            background: white;
            border: 1px solid #e5e7eb;
            box-shadow: 0 10px 30px rgba(0,0,0,.06);
        }

        .btn{
            background:#111827;
            color:white;
            transition:.2s;
        }

        .btn:hover{
            background:#000;
        }
    </style>
</head>
<body>

<div class="max-w-4xl mx-auto px-6 py-12">

    <!-- Header -->
    <div class="flex items-center justify-between border-b pb-6">

        <div>
            <p class="text-gray-500 uppercase tracking-[4px] text-sm">
                Task Details
            </p>

            <h1 class="display text-5xl font-bold text-gray-900 mt-2 break-all">
                <%= filename %>
            </h1>
        </div>

        <a href="/"
           class="btn px-6 py-3 rounded-lg font-medium">
            ← Back
        </a>

    </div>

    <!-- Content Card -->
    <div class="card rounded-2xl p-8 mt-10">

        <h2 class="display text-2xl font-semibold text-gray-800 mb-6">
            Description
        </h2>

        <p class="text-gray-700 text-lg leading-8 whitespace-pre-wrap break-words">
            <%= filedata %>
        </p>

    </div>

</div>

</body>
</html>