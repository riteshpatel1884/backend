<!DOCTYPE html>
<html lang="en" class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Registered Users</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
    }
  </script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
</head>
<body class="bg-zinc-100 dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 min-h-screen transition-colors duration-200">

  <div class="max-w-6xl mx-auto px-6 py-10">

    <!-- Top Bar -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-medium tracking-tight">Registered Users</h1>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-0.5">Manage and review all user accounts</p>
      </div>
      <div class="flex items-center gap-3">
        <!-- Dark mode toggle -->
        <div class="flex items-center gap-2">
         
          <button
            id="themeToggle"
            onclick="toggleTheme()"
            class="relative w-11 h-6 rounded-full border border-zinc-300 dark:border-zinc-700 bg-zinc-200 dark:bg-zinc-800 transition-colors duration-200 focus:outline-none"
            aria-label="Toggle dark mode"
          >
            <span
              id="knob"
              class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-zinc-900 dark:bg-zinc-100 transition-all duration-200 translate-x-0 dark:translate-x-5"
            ></span>
          </button>
          
        </div>
        
      </div>
    </div>


    <!-- User Cards Grid -->
   
<div id="userGrid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">

  <% if(users.length > 0) { %>
    <% users.forEach(function(user){ %>
      <div class="card bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-2xl p-4 hover:border-zinc-400 dark:hover:border-zinc-600 transition-colors">
        <div class="w-full h-36 rounded-xl bg-violet-100 dark:bg-violet-950 flex items-center justify-center mb-4">
          <img class="w-full h-full object-cover rounded-xl" src="<%= user.image %>">
        </div>
        <h3 class="text-sm font-medium truncate"><%= user.name %></h3>
        <p class="text-xs text-zinc-500 dark:text-zinc-400 truncate mb-3"><%= user.email %></p>
        <div class="flex items-center gap-3 pt-3 border-t border-zinc-100 dark:border-zinc-800">
          <a href="/edit/<%= user._id %>" class="text-xs text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 flex items-center gap-1 transition-colors">
            <i class="ti ti-edit text-sm"></i> Edit
          </a>
          <a href="/delete/<%= user._id %>" class="text-xs text-red-500 hover:text-red-600 flex items-center gap-1 ml-auto transition-colors">
            <i class="ti ti-trash text-sm"></i> Delete
          </a>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="col-span-5 text-center py-16 text-zinc-400">
      <i class="ti ti-users-off text-4xl mb-3 block"></i>
      <p class="text-sm">No users found.</p>
    </div>
  <% } %>

</div>

   

  </div>

  <script>
    function toggleTheme() {
      const html = document.documentElement;
      html.classList.toggle('dark');
    }

    function filterCards() {
      const q = document.getElementById('searchInput').value.toLowerCase();
      const cards = document.querySelectorAll('#userGrid .card');
      let visible = 0;
      cards.forEach(card => {
        const match = card.dataset.name.includes(q) || card.dataset.email.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      document.getElementById('emptyState').classList.toggle('hidden', visible > 0);
    }
  </script>

</body>
</html>