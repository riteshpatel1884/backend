<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Create Account</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
    .input-field {
      width: 100%;
      padding: 11px 14px;
      border: 1.5px solid #e5e7eb;
      border-radius: 8px;
      font-size: 15px;
      color: #111827;
      background: #fff;
      outline: none;
      transition: border-color 0.15s;
    }
    .input-field:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.10); }
    .input-field::placeholder { color: #9ca3af; }
  </style>
</head>
<body class="min-h-screen bg-white flex items-center justify-center px-4">

  <div class="w-full max-w-md">

    <!-- Logo / Brand -->
    <div class="mb-8 text-center">
      
      <h1 class="text-2xl font-bold text-gray-900">Create your account</h1>
      
    </div>

    <!-- Card -->
    <div class="bg-white ">
      <form action="/register" method="POST" class="space-y-5">

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Full Name</label>
            <input class="input-field" type="text" placeholder="John Doe" name="name" required />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Username</label>
            <input class="input-field" type="text" placeholder="johndoe" name="username" required />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
          <input class="input-field" type="email" placeholder="john@example.com" name="email" required />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Password</label>
          <input class="input-field" type="password" placeholder="Min. 8 characters" name="password" required />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Age</label>
          <input class="input-field" type="number" placeholder="25" name="age" min="1" max="120" required />
        </div>

        <button
          type="submit"
          class="w-full bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white font-semibold py-3 rounded-lg transition-colors text-sm mt-2"
        >
          Create Account
        </button>

      </form>
    </div>

    <p class="text-center text-sm text-gray-500 mt-6">
      Already have an account?
      <a href="/login" class="text-blue-600 font-medium hover:underline">Sign in</a>
    </p>

  </div>
</body>
</html>